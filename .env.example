# EngageIQ Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Server
PORT=3000

# Data source
# Set to 'true' to use real Microsoft Graph API
# Leave as 'false' to use mock data
USE_REAL_DATA=false

# Claude AI (optional - for live AI insights)
# Get your key from: console.anthropic.com
CLAUDE_API_KEY=your_claude_api_key_here

# Microsoft Graph API (only needed when USE_REAL_DATA=true)
# Get these from Azure Portal > App Registrations > EngageIQ
AZURE_TENANT_ID=your_tenant_id_here
AZURE_CLIENT_ID=your_client_id_here
AZURE_CLIENT_SECRET=your_client_secret_here
